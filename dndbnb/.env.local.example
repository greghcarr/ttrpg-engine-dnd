# Supabase project credentials for dndbnb local dev.
#
# Copy this file to `dndbnb/.env.local` and fill in the two values
# from your Supabase project: Settings -> API.
#
# The anon key is safe to commit to source control if you do the
# whole sharing in public, but since we keep .env.local out of git
# (see .gitignore), treat both values as project-scoped secrets.

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY
