node_modules
dist/
dist-web/
dist-dndbnb/
release/
coverage/
# `coverage/` above matches anywhere — un-ignore the feature-coverage
# matrix test directory which shares the name (Layer 8 of the testing
# standard, per CLAUDE.md).
!tests/coverage/
.DS_Store
*.log
.env*
# Templates checked in deliberately so contributors know which env
# vars to set (dndbnb/.env.local.example).
!.env*.example
*.tsbuildinfo
.claude/
# `references/` holds local-only reference material (the SRD PDF
# source, scratch extractions, etc.). The only canonical surface is
# the SRD 5.2.1 markdown at `references/srd-markdown/`, which lands
# as a git submodule (see .gitmodules and CLAUDE.md "SRD is canon").
# Whitelist the submodule, ignore everything else under references/.
references/*
!references/srd-markdown
!references/srd-markdown/
