{
  "name": "dnd-srd-engine",
  "version": "0.1.0-alpha.5",
  "private": true,
  "description": "Standalone, event-sourced TypeScript domain engine for D&D 5.5e (2024 rules). Schema-only content model with effect-primitive vocabulary and code-handler escape hatch.",
  "type": "module",
  "main": "./dist/dnd-srd-engine.cjs",
  "module": "./dist/dnd-srd-engine.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/dnd-srd-engine.js",
      "require": "./dist/dnd-srd-engine.cjs"
    },
    "./starter-pack": {
      "types": "./dist/starter-pack.d.ts",
      "import": "./dist/starter-pack.js",
      "require": "./dist/starter-pack.cjs"
    }
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "CHANGELOG.md",
    "VERSIONING.md",
    "DEVELOPMENT.md",
    "CONTRIBUTING.md",
    "LICENSE",
    "NOTICE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly --project tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "ci": "npm run typecheck && npm run test:coverage && npm run build",
    "dev:web": "vite --config vite.web.config.ts",
    "build:web": "vite build --config vite.web.config.ts",
    "preview:web": "vite preview --config vite.web.config.ts",
    "dev:dndbnb": "vite --config vite.dndbnb.config.ts",
    "build:dndbnb": "vite build --config vite.dndbnb.config.ts",
    "preview:dndbnb": "vite preview --config vite.dndbnb.config.ts"
  },
  "dependencies": {
    "immer": "^10.1.1",
    "ulid": "^2.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "@types/node": "^25.7.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^1.6.0",
    "fast-check": "^3.23.2",
    "obscenity": "^0.4.3",
    "pdf-lib": "^1.17.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^1.6.0",
    "zustand": "^4.5.5"
  },
  "license": "MIT",
  "author": "Greg Carr",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/greghcarr/dnd-srd-engine.git"
  },
  "bugs": {
    "url": "https://github.com/greghcarr/dnd-srd-engine/issues"
  },
  "homepage": "https://github.com/greghcarr/dnd-srd-engine#readme",
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "dnd",
    "dungeons-and-dragons",
    "5e",
    "5.5e",
    "2024",
    "rules-engine",
    "domain-engine",
    "event-sourced",
    "ttrpg",
    "rpg",
    "character-sheet",
    "vtt",
    "game-engine",
    "typescript"
  ]
}
